# =============================================================================
# Tool Handlers
# =============================================================================

def handle_kb_add(topic: str, title: str, content: str, tags: list = None) -> dict:
    """Add a knowledge entry."""
    try:
        kb_id = f"kb_{uuid.uuid4().hex[:12]}"
        timestamp = datetime.utcnow().isoformat()

        entry = {
            "kb_id": kb_id,
            "topic": topic,
            "title": title,
            "content": content,
            "tags": tags or [],
            "timestamp": timestamp
        }

        # Save to topic-specific file
        topic_file = KB_DIR / f"{topic}.json"
        entries = load_json(topic_file, [])
        entries.append(entry)
        save_json(topic_file, entries)

        return ResponseEnvelope.success(
            f"Added KB entry '{title}' ({kb_id})",
            {"kb_id": kb_id, "timestamp": timestamp}
        )
    except Exception as e:
        logger.error(f"Error in kb_add: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kb_search(query: str, topic: str = None) -> dict:
    """Search knowledge base."""
    try:
        results = []
        if topic:
            files = [KB_DIR / f"{topic}.json"]
        else:
            files = list(KB_DIR.glob("*.json"))

        query_lower = query.lower()
        for file in files:
            if not file.exists():
                continue
            entries = load_json(file, [])
            for entry in entries:
                if (query_lower in entry.get("title", "").lower() or
                    query_lower in entry.get("content", "").lower() or
                    query_lower in " ".join(entry.get("tags", [])).lower()):
                    results.append({
                        "kb_id": entry["kb_id"],
                        "topic": entry["topic"],
                        "title": entry["title"],
                        "snippet": entry["content"][:200] + "..." if len(entry["content"]) > 200 else entry["content"],
                        "tags": entry["tags"],
                        "timestamp": entry["timestamp"]
                    })

        return ResponseEnvelope.success(
            f"Found {len(results)} KB entries",
            {"results": results, "count": len(results)}
        )
    except Exception as e:
        logger.error(f"Error in kb_search: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kb_get(kb_id: str) -> dict:
    """Fetch full KB entry."""
    try:
        for file in KB_DIR.glob("*.json"):
            entries = load_json(file, [])
            for entry in entries:
                if entry["kb_id"] == kb_id:
                    return ResponseEnvelope.success(f"KB entry {kb_id}", {"entry": entry})
        return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"KB entry {kb_id} not found")
    except Exception as e:
        logger.error(f"Error in kb_get: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kb_list(topic: str = None) -> dict:
    """List KB entries by topic."""
    try:
        entries = []
        if topic:
            files = [KB_DIR / f"{topic}.json"]
        else:
            files = list(KB_DIR.glob("*.json"))

        for file in files:
            if not file.exists():
                continue
            file_entries = load_json(file, [])
            for entry in file_entries:
                entries.append({
                    "kb_id": entry["kb_id"],
                    "topic": entry["topic"],
                    "title": entry["title"],
                    "tags": entry["tags"],
                    "timestamp": entry["timestamp"]
                })

        return ResponseEnvelope.success(
            f"Found {len(entries)} KB entries",
            {"entries": entries, "count": len(entries)}
        )
    except Exception as e:
        logger.error(f"Error in kb_list: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kg_add_node(label: str, kind: str, properties: dict = None) -> dict:
    """Add a concept node."""
    try:
        node_id = f"node_{uuid.uuid4().hex[:8]}"
        timestamp = datetime.utcnow().isoformat()

        node = {
            "node_id": node_id,
            "label": label,
            "kind": kind,
            "properties": properties or {},
            "timestamp": timestamp
        }

        nodes = load_json(KG_DIR / "nodes.json", [])
        nodes.append(node)
        save_json(KG_DIR / "nodes.json", nodes)

        return ResponseEnvelope.success(
            f"Added node '{label}' ({node_id})",
            {"node_id": node_id, "timestamp": timestamp}
        )
    except Exception as e:
        logger.error(f"Error in kg_add_node: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kg_add_edge(source_id: str, target_id: str, relation: str, properties: dict = None) -> dict:
    """Link two nodes."""
    try:
        edge_id = f"edge_{uuid.uuid4().hex[:8]}"
        timestamp = datetime.utcnow().isoformat()

        # Verify nodes exist
        nodes = load_json(KG_DIR / "nodes.json", [])
        node_ids = {node["node_id"] for node in nodes}

        if source_id not in node_ids:
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Source node {source_id} not found")
        if target_id not in node_ids:
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Target node {target_id} not found")

        edge = {
            "edge_id": edge_id,
            "source_id": source_id,
            "target_id": target_id,
            "relation": relation,
            "properties": properties or {},
            "timestamp": timestamp
        }

        edges = load_json(KG_DIR / "edges.json", [])
        edges.append(edge)
        save_json(KG_DIR / "edges.json", edges)

        return ResponseEnvelope.success(
            f"Linked {source_id} → {target_id} ({relation})",
            {"edge_id": edge_id, "timestamp": timestamp}
        )
    except Exception as e:
        logger.error(f"Error in kg_add_edge: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kg_get_node(node_id: str) -> dict:
    """Fetch node with edges."""
    try:
        nodes = load_json(KG_DIR / "nodes.json", [])
        edges = load_json(KG_DIR / "edges.json", [])

        node = next((n for n in nodes if n["node_id"] == node_id), None)
        if not node:
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Node {node_id} not found")

        outgoing = [e for e in edges if e["source_id"] == node_id]
        incoming = [e for e in edges if e["target_id"] == node_id]

        return ResponseEnvelope.success(
            f"Node {node_id}",
            {"node": node, "outgoing_edges": outgoing, "incoming_edges": incoming}
        )
    except Exception as e:
        logger.error(f"Error in kg_get_node: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kg_neighbors(node_id: str, max_hops: int = 1) -> dict:
    """Explore graph neighborhood."""
    try:
        nodes = load_json(KG_DIR / "nodes.json", [])
        edges = load_json(KG_DIR / "edges.json", [])

        if not any(n["node_id"] == node_id for n in nodes):
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Node {node_id} not found")

        visited = {node_id}
        current_level = {node_id}
        all_edges = []

        for hop in range(max_hops):
            next_level = set()
            for current in current_level:
                for edge in edges:
                    if edge["source_id"] == current:
                        next_level.add(edge["target_id"])
                        all_edges.append(edge)
                    elif edge["target_id"] == current:
                        next_level.add(edge["source_id"])
                        all_edges.append(edge)

            new_nodes = next_level - visited
            visited.update(new_nodes)
            current_level = new_nodes

            if not current_level:
                break

        neighbor_nodes = [n for n in nodes if n["node_id"] in visited and n["node_id"] != node_id]

        return ResponseEnvelope.success(
            f"Found {len(neighbor_nodes)} neighbors within {max_hops} hops",
            {"neighbors": neighbor_nodes, "edges": all_edges, "count": len(neighbor_nodes)}
        )
    except Exception as e:
        logger.error(f"Error in kg_neighbors: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_kg_search(query: str) -> dict:
    """Search graph nodes by text."""
    try:
        nodes = load_json(KG_DIR / "nodes.json", [])
        query_lower = query.lower()

        results = []
        for node in nodes:
            if (query_lower in node.get("label", "").lower() or
                query_lower in node.get("kind", "").lower() or
                query_lower in json.dumps(node.get("properties", {})).lower()):
                results.append(node)

        return ResponseEnvelope.success(
            f"Found {len(results)} nodes",
            {"results": results, "count": len(results)}
        )
    except Exception as e:
        logger.error(f"Error in kg_search: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


