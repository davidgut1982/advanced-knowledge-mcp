def handle_research_list_notes(topic: str = None) -> dict:
    """List research notes."""
    try:
        notes_file = RESEARCH_DIR / "notes.json"
        notes = load_json(notes_file, [])

        if topic:
            notes = [n for n in notes if n.get("topic") == topic]

        summaries = [{
            "note_id": n["note_id"],
            "topic": n["topic"],
            "title": n["title"],
            "tags": n["tags"],
            "timestamp": n["timestamp"]
        } for n in notes]

        return ResponseEnvelope.success(
            f"Found {len(summaries)} research notes",
            {"notes": summaries, "count": len(summaries)}
        )
    except Exception as e:
        logger.error(f"Error in research_list_notes: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_research_get_note(note_id: str) -> dict:
    """Fetch full research note."""
    try:
        notes_file = RESEARCH_DIR / "notes.json"
        notes = load_json(notes_file, [])

        note = next((n for n in notes if n["note_id"] == note_id), None)
        if not note:
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Research note {note_id} not found")

        return ResponseEnvelope.success(f"Research note {note_id}", {"note": note})
    except Exception as e:
        logger.error(f"Error in research_get_note: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


