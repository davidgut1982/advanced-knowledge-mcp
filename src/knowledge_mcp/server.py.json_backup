def handle_research_log_experiment(topic: str, hypothesis: str, config_ref: str,
                                    result_summary: str, tags: list = None) -> dict:
    """Log an experiment."""
    try:
        exp_id = f"exp_{uuid.uuid4().hex[:12]}"
        timestamp = datetime.utcnow().isoformat()

        experiment = {
            "experiment_id": exp_id,
            "topic": topic,
            "hypothesis": hypothesis,
            "config_ref": config_ref,
            "result_summary": result_summary,
            "tags": tags or [],
            "timestamp": timestamp,
            "linked_sources": []
        }

        experiments_file = RESEARCH_DIR / "experiments.json"
        experiments = load_json(experiments_file, [])
        experiments.append(experiment)
        save_json(experiments_file, experiments)

        return ResponseEnvelope.success(
            f"Logged experiment ({exp_id})",
            {"experiment_id": exp_id, "timestamp": timestamp}
        )
    except Exception as e:
        logger.error(f"Error in research_log_experiment: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_research_list_experiments(topic: str = None) -> dict:
    """List experiments."""
    try:
        experiments_file = RESEARCH_DIR / "experiments.json"
        experiments = load_json(experiments_file, [])

        if topic:
            experiments = [e for e in experiments if e.get("topic") == topic]

        summaries = [{
            "experiment_id": e["experiment_id"],
            "topic": e["topic"],
            "hypothesis": e["hypothesis"],
            "config_ref": e["config_ref"],
            "tags": e["tags"],
            "timestamp": e["timestamp"]
        } for e in experiments]

        return ResponseEnvelope.success(
            f"Found {len(summaries)} experiments",
            {"experiments": summaries, "count": len(summaries)}
        )
    except Exception as e:
        logger.error(f"Error in research_list_experiments: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_research_link_source_to_experiment(source_id: str, experiment_id: str) -> dict:
    """Link a source to an experiment."""
    try:
        experiments_file = RESEARCH_DIR / "experiments.json"
        experiments = load_json(experiments_file, [])

        experiment = next((e for e in experiments if e["experiment_id"] == experiment_id), None)
        if not experiment:
            return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Experiment {experiment_id} not found")

        if source_id not in experiment["linked_sources"]:
            experiment["linked_sources"].append(source_id)
            save_json(experiments_file, experiments)

        return ResponseEnvelope.success(
            f"Linked source {source_id} to experiment {experiment_id}",
            {"experiment_id": experiment_id, "linked_sources": experiment["linked_sources"]}
        )
    except Exception as e:
        logger.error(f"Error in research_link_source_to_experiment: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_journal_append(topic: str, title: str, content: str, tags: list = None) -> dict:
    """Persist decisions/notes to journal."""
    try:
        entry_id = f"journal_{uuid.uuid4().hex[:12]}"
        timestamp = datetime.utcnow().isoformat()

        entry = {
            "entry_id": entry_id,
            "topic": topic,
            "title": title,
            "content": content,
            "tags": tags or [],
            "timestamp": timestamp
        }

        journal_file = JOURNAL_DIR / f"{topic}.json"
        entries = load_json(journal_file, [])
        entries.append(entry)
        save_json(journal_file, entries)

        return ResponseEnvelope.success(
            f"Added journal entry '{title}' ({entry_id})",
            {"entry_id": entry_id, "timestamp": timestamp}
        )
    except Exception as e:
        logger.error(f"Error in journal_append: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_journal_list(topic: str = None) -> dict:
    """List journal entries."""
    try:
        entries = []

        if topic:
            files = [JOURNAL_DIR / f"{topic}.json"]
        else:
            files = list(JOURNAL_DIR.glob("*.json"))

        for file in files:
            if not file.exists() or file.name == "snapshots.json":
                continue
            file_entries = load_json(file, [])
            for entry in file_entries:
                entries.append({
                    "entry_id": entry["entry_id"],
                    "topic": entry["topic"],
                    "title": entry["title"],
                    "tags": entry["tags"],
                    "timestamp": entry["timestamp"]
                })

        return ResponseEnvelope.success(
            f"Found {len(entries)} journal entries",
            {"entries": entries, "count": len(entries)}
        )
    except Exception as e:
        logger.error(f"Error in journal_list: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_journal_get(entry_id: str) -> dict:
    """Fetch full journal entry."""
    try:
        for file in JOURNAL_DIR.glob("*.json"):
            if file.name == "snapshots.json":
                continue
            entries = load_json(file, [])
            for entry in entries:
                if entry["entry_id"] == entry_id:
                    return ResponseEnvelope.success(f"Journal entry {entry_id}", {"entry": entry})

        return ResponseEnvelope.error(ErrorCodes.NOT_FOUND, f"Journal entry {entry_id} not found")
    except Exception as e:
        logger.error(f"Error in journal_get: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


def handle_snapshot_config(label: str, config_paths: list = None) -> dict:
    """Snapshot key configs under a label."""
    try:
        timestamp = datetime.utcnow().isoformat()

        if not config_paths:
            config_paths = [
                "/srv/latvian_learning/config.yaml",
                "/srv/latvian_xtts/config/training_config.yaml",
            ]

        snapshot = {
            "label": label,
            "timestamp": timestamp,
            "configs": {}
        }

        for path in config_paths:
            if Path(path).exists():
                with open(path) as f:
                    if path.endswith('.yaml') or path.endswith('.yml'):
                        snapshot["configs"][path] = yaml.safe_load(f)
                    elif path.endswith('.json'):
                        snapshot["configs"][path] = json.load(f)
                    else:
                        snapshot["configs"][path] = f.read()

        snapshots_file = JOURNAL_DIR / "snapshots.json"
        snapshots = load_json(snapshots_file, [])
        snapshots.append(snapshot)
        save_json(snapshots_file, snapshots)

        return ResponseEnvelope.success(
            f"Snapshotted {len(snapshot['configs'])} configs as '{label}'",
            {
                "label": label,
                "timestamp": timestamp,
                "config_count": len(snapshot['configs']),
                "paths": list(snapshot['configs'].keys())
            }
        )
    except Exception as e:
        logger.error(f"Error in snapshot_config: {e}")
        return ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e))


# =============================================================================
# Tool Router
# =============================================================================

@app.call_tool()
async def call_tool(name: str, arguments: Any) -> list[types.TextContent]:
    """Handle tool calls."""
    try:
        # Knowledge Base Tools
        if name == "kb_add":
            return format_response(handle_kb_add(**arguments))
        elif name == "kb_search":
            return format_response(handle_kb_search(**arguments))
        elif name == "kb_get":
            return format_response(handle_kb_get(**arguments))
        elif name == "kb_list":
            return format_response(handle_kb_list(**arguments))

        # Knowledge Graph Tools
        elif name == "kg_add_node":
            return format_response(handle_kg_add_node(**arguments))
        elif name == "kg_add_edge":
            return format_response(handle_kg_add_edge(**arguments))
        elif name == "kg_get_node":
            return format_response(handle_kg_get_node(**arguments))
        elif name == "kg_neighbors":
            return format_response(handle_kg_neighbors(**arguments))
        elif name == "kg_search":
            return format_response(handle_kg_search(**arguments))

        # Research Tools
        elif name == "research_add_note":
            return format_response(handle_research_add_note(**arguments))
        elif name == "research_list_notes":
            return format_response(handle_research_list_notes(**arguments))
        elif name == "research_get_note":
            return format_response(handle_research_get_note(**arguments))
        elif name == "research_add_source":
            return format_response(handle_research_add_source(**arguments))
        elif name == "research_list_sources":
            return format_response(handle_research_list_sources())
        elif name == "research_log_experiment":
            return format_response(handle_research_log_experiment(**arguments))
        elif name == "research_list_experiments":
            return format_response(handle_research_list_experiments(**arguments))
        elif name == "research_link_source_to_experiment":
            return format_response(handle_research_link_source_to_experiment(**arguments))

        # Journal Tools
        elif name == "journal_append":
            return format_response(handle_journal_append(**arguments))
        elif name == "journal_list":
            return format_response(handle_journal_list(**arguments))
        elif name == "journal_get":
            return format_response(handle_journal_get(**arguments))
        elif name == "snapshot_config":
            return format_response(handle_snapshot_config(**arguments))

        else:
            return format_response(ResponseEnvelope.error(
                ErrorCodes.INVALID_ARGUMENT,
                f"Unknown tool: {name}"
            ))

    except Exception as e:
        logger.error(f"Error calling tool {name}: {e}")
        return format_response(ResponseEnvelope.error(ErrorCodes.UNEXPECTED, str(e)))


def main():
    """Run the MCP server."""
    import asyncio
    logger.info("Starting knowledge-mcp server")

    async def _run():
        async with stdio_server() as (read_stream, write_stream):
            await app.run(read_stream, write_stream, app.create_initialization_options())

    asyncio.run(_run())


if __name__ == "__main__":
    main()
