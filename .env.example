# Knowledge-MCP Environment Configuration
# Copy this file to .env and configure for your environment

# =============================================================================
# Database Backend Selection (choose one)
# =============================================================================

# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://knowledge_user:password@localhost:5432/knowledge_db

# OR Supabase (Managed cloud PostgreSQL)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_service_role_key_here

# OR JSON Files (Development fallback)
# KNOWLEDGE_DATA_DIR=/opt/knowledge-data

# =============================================================================
# Optional Configuration
# =============================================================================

# Error Monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Performance Tuning
MAX_CHUNK_SIZE=2000
CONCURRENT_INGESTION_LIMIT=10
BATCH_SIZE=50

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_VECTOR_SEARCH=true
ENABLE_QUERY_CACHE=false

# =============================================================================
# Security Configuration
# =============================================================================

# Data directory permissions (JSON backend only)
# Ensure this directory is writable by the knowledge-mcp process
# and not accessible by other users
KNOWLEDGE_DATA_DIR_MODE=0700

# Database SSL (for remote PostgreSQL)
# DATABASE_SSL_MODE=require
# DATABASE_SSL_CERT=/path/to/client.crt
# DATABASE_SSL_KEY=/path/to/client.key